# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# tina
tina/__generated__
public/admin

*storybook.log
storybook-static

# wyw-in-js generated CSS modules (build artifact)
*.wyw-in-js.module.css

.idea

# .claude lokal halten — außer dem skills-Verweis auf .agents/skills
.claude/*
!.claude/skills

# UPPERCASE.md sind temporäre Arbeitsnotizen (ADR 0013)
[A-Z]*[A-Z].md
!README.md
!CLAUDE.md
!SKILL.md
!SECURITY.md
