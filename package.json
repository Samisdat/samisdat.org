{
  "name": "samisdat-workspace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:lib": "pnpm --filter @samisdat/wtal-panorama build:lib",
    "dev:app": "pnpm --filter @samisdat/wtal-panorama dev",
    "dev:lib": "pnpm --filter @samisdat/wtal-panorama dev:lib",
    "dev": "pnpm --filter @samisdat/website dev",
    "dev:all": "concurrently \"pnpm dev:lib\" \"pnpm dev\"",
    "build": "pnpm run build:lib && pnpm --filter @samisdat/website build",
    "storybook": "pnpm --filter @samisdat/ui-components storybook",
    "build-storybook": "pnpm --filter @samisdat/ui-components build-storybook",
    "lint:css": "stylelint \"**/*.{ts,tsx}\" --ignore-path .gitignore",
    "lint:colors": "./scripts/lint-colors.sh",
    "check:versions": "syncpack lint",
    "fix:versions": "syncpack fix-mismatches"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "postcss-styled-syntax": "^0.7.2",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "syncpack": "^14.1.0"
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
