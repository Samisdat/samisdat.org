{
  "name": "samisdat-workspace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:lib": "pnpm --filter @samisdat/wtal-panorama build:lib",
    "dev:app": "pnpm --filter @samisdat/wtal-panorama dev",
    "dev:lib": "pnpm --filter @samisdat/wtal-panorama dev:lib",
    "dev": "pnpm --filter blog dev",
    "dev:all": "pnpm dev:lib & pnpm dev",
    "build": "pnpm run build:lib && pnpm --filter blog build",
    "storybook": "pnpm --filter @samisdat/ui-components storybook",
    "build-storybook": "pnpm --filter @samisdat/ui-components build-storybook"
  },
  "dependencies": {
    "chrome-remote-interface": "^0.34.0"
  },
  "devDependencies": {
    "puppeteer": "^25.1.0"
  }
}
