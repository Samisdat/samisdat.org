{
    "name": "@samisdat/wtal-panorama",
    "version": "1.0.0",
    "private": false,
    "type": "module",
    "description": "Wuppertal panorama with realistic astronomical sun and moon animations",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/index.cjs",
            "import": "./dist/index.js"
        },
        "./style.css": "./src/components/panorama.css"
    },
    "files": [
        "dist",
        "src/components/panorama.css"
    ],
    "scripts": {
        "dev": "next dev",
        "dev:lib": "tsup src/index.tsx --format cjs,esm --dts --tsconfig tsconfig.lib.json --external react --external react-dom --watch",
        "build": "next build",
        "build:lib": "tsup src/index.tsx --format cjs,esm --tsconfig tsconfig.lib.json --external react --external react-dom && tsc --project tsconfig.lib.json --declaration --emitDeclarationOnly --outDir dist",
        "start": "next start",
        "lint": "oxlint .",
        "test": "vitest",
        "test:run": "vitest run",
        "format": "prettier --write \"./**/*.{ts,tsx}\" --config ./.prettierrc.cjs",
        "prepublishOnly": "npm run build:lib"
    },
    "keywords": [
        "wuppertal",
        "panorama",
        "svg",
        "animation",
        "sun",
        "moon",
        "astronomy",
        "react",
        "suncalc"
    ],
    "author": "Bastian Pertz <bastian@pertz.eu> (https://samisdat.org/)",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Samisdat/samisdat.org.git",
        "directory": "packages/panorama"
    },
    "peerDependencies": {
        "react": "^19.2.7",
        "react-dom": "^19.2.7"
    },
    "devDependencies": {
        "@samisdat/tools": "workspace:*",
        "@types/node": "catalog:",
        "@types/react": "catalog:",
        "@types/react-dom": "catalog:",
        "@types/suncalc": "^1.9.2",
        "next": "catalog:",
        "prettier": "catalog:",
        "prettier-plugin-multiline-arrays": "catalog:",
        "prettier-plugin-organize-imports": "catalog:",
        "react": "catalog:",
        "react-dom": "catalog:",
        "suncalc": "^2.0.1",
        "tsup": "^8.5.0",
        "typescript": "catalog:",
        "vitest": "catalog:"
    },
    "dependencies": {
        "astronomy-engine": "^2.1.1"
    }
}
